{
  "rewrites": [
    {
      "source": "/invoices/:slug",
      "destination": "/api/invoice-view?slug=:slug"
    },
    {
      "source": "/invoice/:uid/:branch/:billNo",
      "destination": "/api/invoice-view?uid=:uid&branch=:branch&billNo=:billNo"
    },
    {
      "source": "/invoice/:fileKey",
      "destination": "/api/invoice?fileKey=:fileKey"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
